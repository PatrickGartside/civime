#: front-page.php:320
msgid "Civic tools"
msgstr "Mea hana kīwila"

#: front-page.php:322
msgid "What you can do on Civi.Me"
msgstr "Ka mea āu e hana ai ma Civi.Me"

#: front-page.php:363
#: front-page.php:403
